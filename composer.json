{
    "name": "craftzing/laravel-abilities",
    "description": "Improved class-based abilities for Laravel Gate",
    "keywords": ["php", "laravel", "laravel-framework", "laravel-gate", "policies", "abilities"],
    "type": "library",
    "homepage": "https://github.com/craftzing/laravel-abilities",
    "support": {
        "issues": "https://github.com/craftzing/laravel-abilities/issues",
        "source": "https://github.com/craftzing/laravel-abilities"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Rémi Pelhate",
            "email": "remi.pelhate@craftzing.com"
        },
        {
            "name": "Pieter Pelgrims",
            "email": "pieter.pelgrims@craftzing.com"
        }
    ],
    "require": {
        "php": "8.3.*|8.4.*",
        "illuminate/auth": "^10.10.0|^11.0",
        "illuminate/contracts": "^10.10.0|^11.0",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "friendsofphp/php-cs-fixer": "^3.68",
        "illuminate/container": "^10.10.0|^11.0",
        "orchestra/testbench": "^9.9",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Craftzing\\Laravel\\Abilities\\": "src"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs:check": "PHP_CS_FIXER_IGNORE_ENV=1 vendor/bin/php-cs-fixer fix --verbose --dry-run",
        "cs:fix": "PHP_CS_FIXER_IGNORE_ENV=1 vendor/bin/php-cs-fixer fix --verbose",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G --ansi",
        "phpunit": "vendor/bin/phpunit --colors=always --display-phpunit-deprecations --display-deprecations",
        "test": [
            "@composer cs:check",
            "@composer phpstan",
            "@composer phpunit"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0.x-dev"
        },
        "laravel": {
            "providers": [
                "Craftzing\\Laravel\\Abilities\\ServiceProvider"
            ]
        }
    }
}
